{
  "_comment": "Central config for resource names. provision.ps1 reads/creates these. Edit names before provisioning. No secrets here - secrets live in Key Vault and are referenced by name.",

  "location": "eastus",
  "resourceGroup": "rg-rcm-demo",

  "storage": {
    "accountName": "strcmdemo70648c",
    "containers": ["landing", "bronze", "silver", "gold", "quarantine", "checkpoints", "metadata"]
  },

  "azureSql": {
    "serverName": "sqlrcmb70648c",
    "location": "centralus",
    "_locationNote": "SQL placed in centralus; eastus/eastus2 were capacity-blocked (RegionDoesNotAllowProvisioning) for this trial subscription.",
    "databaseName": "emr_source",
    "adminUser": "rcmadmin",
    "adminPasswordSecretName": "sql-admin-password",
    "skuName": "GP_S_Gen5_1",
    "autoPauseDelayMinutes": 60,
    "minCapacity": 0.5
  },

  "databricks": {
    "workspaceName": "dbw-rcm-demo",
    "sku": "premium",
    "catalog": "rcm",
    "schemas": ["bronze", "silver", "gold", "audit"],
    "clusterAutoTerminationMinutes": 10,
    "_autoTermNote": "Strict: 10 is the Databricks minimum. Idle compute terminates fast to protect trial credits."
  },

  "dataFactory": {
    "name": "adf-rcm-demo-70648c"
  },

  "keyVault": {
    "name": "kv-rcm-demo-70648c",
    "secretScope": "rcm-secrets"
  },

  "budget": {
    "name": "rcm-demo-budget",
    "amount": 200,
    "thresholdPercents": [25, 50, 75, 90],
    "contactEmail": "lprashant1941@gmail.com"
  },

  "paths": {
    "landingClaims": "landing/claims/",
    "landingTelemetry": "landing/telemetry/",
    "bronzeRoot": "bronze/",
    "silverRoot": "silver/",
    "goldRoot": "gold/",
    "quarantineRoot": "quarantine/",
    "checkpointsRoot": "checkpoints/"
  }
}
